APP_NAME="Frontend Laravel"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Produccion: https://delicias.saborcentral.com
APP_URL=http://localhost
APP_TIMEZONE=America/Lima
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

LOG_CHANNEL=stderr
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database

FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/register/google/callback"

# Produccion: https://api.saborcentral.com
BACKEND_API_BASE_URL=http://127.0.0.1:5001
JWT_SECRET=

RUN_MIGRATIONS=false
PORT=6000

YAPE_QR_URL=https://delicias.saborcentral.com/images/payments/yape-qr.png
YAPE_PHONE=974268690
DOCUMENT_VALIDATION_REQUIRED=true

APIPERU_TOKEN=
DECOLECTA_TOKEN=
DECOLECTA_BASE_URL=https://api.decolecta.com/v1

CHATBOT_ENABLE_OLLAMA=false
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_SECONDS=20
